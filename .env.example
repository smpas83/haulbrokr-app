# HaulBrokr — environment variable template
# Copy to `.env` and fill in real values. NEVER commit a filled-in .env.
# See MIGRATION_TO_CURSOR.md §4 for which artifact reads each variable.

# ---- Database (Neon in production — see docs/DEPLOY-VERCEL-RENDER.md) ----
DATABASE_URL=

# ---- Production URLs (reference only — set in host dashboards) ----
# Web: haulbrokr.com (Vercel)
# API: haulbrokr-api.onrender.com (Render, proxied via Vercel /api)
# Mobile EXPO_PUBLIC_DOMAIN: haulbrokr.com

# ---- Auth: Clerk ----
# Backend (api-server)
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=
# Web app (artifacts/haulbrokr)
VITE_CLERK_PUBLISHABLE_KEY=
VITE_CLERK_PROXY_URL=
# Mobile app (artifacts/haulbrokr-mobile)
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=

# ---- Sign in with Apple (HaulBrokr backend owns token exchange + revocation) ----
# Store these in Render/production secret manager. NEVER commit the .p8 key.
APPLE_TEAM_ID=
APPLE_KEY_ID=
# Bundle ID for native iOS (preferred) or Services ID — typically com.haulbrokr.mobile
APPLE_CLIENT_ID=com.haulbrokr.mobile
# PKCS#8 .p8 PEM (literal newlines or \n-escaped). Do not paste into chat/PRs.
APPLE_PRIVATE_KEY=
# 32-byte AES key as 64 hex chars (openssl rand -hex 32) for refresh-token encryption at rest
APPLE_TOKEN_ENCRYPTION_KEY=

# ---- API server ----
ADMIN_USER_IDS=
CORS_ALLOWED_ORIGINS=https://haulbrokr.com,https://www.haulbrokr.com
# Optional: required only if /api/automation/* jobs are enabled.
AUTOMATION_KEY=
# Must be unset or false in production (Render). Local dev only:
PAYMENTS_MOCK_MODE=true
UPLOAD_TOKEN_SECRET=
TICKET_QR_SECRET=
STAFF_AUTH_SECRET=
# Seed staff logins: STAFF_DEFAULT_PASSWORD=... pnpm --filter @workspace/api-server run seed-staff
STAFF_DEFAULT_PASSWORD=
LOG_LEVEL=info

# ---- Payments & email (off Replit) ----
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# ---- Object storage — Cloudflare R2 (api-server) ----
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_URL=
# Key prefixes within R2_BUCKET (leading slash optional)
PRIVATE_OBJECT_DIR=
PUBLIC_OBJECT_SEARCH_PATHS=

# ---- Maps (API server + optional native mobile) ----
# Required in production on Render — validated at API startup when NODE_ENV=production.
GOOGLE_MAPS_API_KEY=

# ---- Mobile app ----
EXPO_PUBLIC_DOMAIN=

# ---- Server ports (set per app when running locally) ----
PORT=
BASE_PATH=/

# ---- Deployment validation script (optional) ----
TARGET_ENV=staging
WEB_URL=https://haulbrokr.com
API_DIRECT=https://haulbrokr-api.onrender.com
# Set to 1 only when real third-party credentials are configured locally/CI.
VERIFY_LIVE_THIRD_PARTY=
# Set to 1 for pre-deployment env-only validation.
SKIP_ENDPOINT_CHECKS=
