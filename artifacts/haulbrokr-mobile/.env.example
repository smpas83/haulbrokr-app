# Mobile app environment for local (non-Replit) development.
# Copy this file to `.env` and fill in real values, then run `pnpm run dev`.
# Expo automatically loads `.env` and exposes EXPO_PUBLIC_* vars to the app.
#
# On Replit these values come from Replit-provided variables instead, so the
# `dev` script only sets them when running on Replit and otherwise falls back
# to what you put here.

# Host (no protocol) used to build the API base URL: https://<domain>/api
# Production: haulbrokr.com (Vercel proxies /api to Render)
EXPO_PUBLIC_DOMAIN=haulbrokr.com

# Clerk publishable key for the mobile app (exactly ONE line — duplicates break loading)
# Production App Store builds MUST use pk_live_... from clerk.haulbrokr.com
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_xxx

# Native Google Sign-In (production iOS release). Get from Clerk Dashboard → Google connection.
# Web client ID is required; iOS client ID + reversed URL scheme required for native iOS Google.
EXPO_PUBLIC_CLERK_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_CLERK_GOOGLE_IOS_CLIENT_ID=
# Reversed iOS client ID, e.g. com.googleusercontent.apps.123456789-abcdef
EXPO_PUBLIC_CLERK_GOOGLE_IOS_URL_SCHEME=

# Android native maps key. Set as an EAS secret for production builds; app.config.js
# injects it into android.config.googleMaps.apiKey only when present.
GOOGLE_MAPS_API_KEY=

# Optional Expo web/mobile fallback when /api/map/config is unavailable locally.
# Production web builds fetch the key from https://<EXPO_PUBLIC_DOMAIN>/api/map/config.
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=

# Optional: Expo/Metro dev server port (defaults to 8081 if unset)
# PORT=8082
