{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "cd ../.. && pnpm install --frozen-lockfile",
  "buildCommand": "cd ../.. && pnpm --filter @workspace/haulbrokr run build",
  "outputDirectory": "dist/public",
  "framework": null,
  "rewrites": [
    {
      "source": "/admin/marketing",
      "destination": "https://kashventure.com/haulbrokr/admin/marketing"
    },
    {
      "source": "/admin/marketing/:path*",
      "destination": "https://kashventure.com/haulbrokr/admin/marketing/:path*"
    },
    {
      "source": "/admin",
      "destination": "https://kashventure.com/haulbrokr/admin"
    },
    {
      "source": "/haulbrokr/admin",
      "destination": "https://kashventure.com/haulbrokr/admin"
    },
    {
      "source": "/haulbrokr/admin/:path*",
      "destination": "https://kashventure.com/haulbrokr/admin/:path*"
    },
    {
      "source": "/api/haulbrokr/marketing/:path*",
      "destination": "https://kashventure.com/api/haulbrokr/marketing/:path*"
    },
    {
      "source": "/__clerk",
      "destination": "https://kashventure.com/__clerk"
    },
    {
      "source": "/__clerk/:path*",
      "destination": "https://kashventure.com/__clerk/:path*"
    },
    {
      "source": "/_next/:path*",
      "destination": "https://kashventure.com/_next/:path*"
    },
    {
      "source": "/sign-up",
      "destination": "https://kashventure.com/sign-up"
    },
    {
      "source": "/sign-up/:path*",
      "destination": "https://kashventure.com/sign-up/:path*"
    },
    {
      "source": "/sign-in",
      "has": [
        {
          "type": "query",
          "key": "redirect_url",
          "value": "(?<ru>.*(?:haulbrokr/admin|admin/marketing|haulbrokr\\.com).*)"
        }
      ],
      "destination": "https://kashventure.com/sign-in"
    },
    {
      "source": "/sign-in/:path*",
      "has": [
        {
          "type": "query",
          "key": "redirect_url",
          "value": "(?<ru>.*(?:haulbrokr/admin|admin/marketing|haulbrokr\\.com).*)"
        }
      ],
      "destination": "https://kashventure.com/sign-in/:path*"
    },
    {
      "source": "/api/:path*",
      "destination": "https://haulbrokr-api.onrender.com/api/:path*"
    },
    {
      "source": "/support",
      "destination": "/support.html"
    },
    {
      "source": "/privacy",
      "destination": "/privacy.html"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/admin",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "private, no-cache, no-store, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/admin/:path*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "private, no-cache, no-store, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/haulbrokr/admin/:path*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "private, no-cache, no-store, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/api/haulbrokr/marketing/:path*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "private, no-cache, no-store, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/sign-in",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "private, no-cache, no-store, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/sign-in/:path*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "private, no-cache, no-store, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/sign-up",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "private, no-cache, no-store, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/sign-up/:path*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "private, no-cache, no-store, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=(self)"
        },
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=31536000; includeSubDomains"
        }
      ]
    }
  ]
}
